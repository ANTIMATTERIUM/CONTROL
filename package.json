{
  "name": "@antimatterium/control",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "ANTIMATTERIUM public cold-replay control plane",
  "scripts": {
    "verify": "node scripts/verify-control.mjs && node scripts/scan-public-safety.mjs && node scripts/verify-ci-gate.mjs && node scripts/verify-ci-evidence-seal.mjs && node scripts/verify-bidirectional-public-closure.mjs && node scripts/verify-stranger-final-audit.mjs && node scripts/verify-public-release-matrix.mjs && node scripts/verify-public-stranger-ci.mjs && node scripts/verify-second-order-public-stranger-ci-closure.mjs && node scripts/verify-public-ecosystem-index.mjs && node scripts/verify-public-ecosystem-index-echo-closure.mjs && node scripts/verify-public-rootless-reconstruction-index.mjs",
    "replay": "bash scripts/cold-replay.sh",
    "scan": "node scripts/scan-public-safety.mjs",
    "verify:ci": "node scripts/verify-ci-gate.mjs",
    "verify:ci-evidence": "node scripts/verify-ci-evidence-seal.mjs",
    "verify:bidirectional-closure": "node scripts/verify-bidirectional-public-closure.mjs",
    "verify:stranger-final-audit": "node scripts/verify-stranger-final-audit.mjs",
    "audit:final": "bash scripts/stranger-final-audit.sh",
    "verify:release-matrix": "node scripts/verify-public-release-matrix.mjs",
    "verify:public-stranger-ci": "node scripts/verify-public-stranger-ci.mjs",
    "audit:backpropagation": "bash scripts/public-stranger-ci-backpropagation-audit.sh",
    "verify:second-order-public-closure": "node scripts/verify-second-order-public-stranger-ci-closure.mjs",
    "verify:ecosystem-index": "node scripts/verify-public-ecosystem-index.mjs",
    "audit:ecosystem-echo": "bash scripts/public-ecosystem-index-echo-audit.sh",
    "verify:ecosystem-echo": "node scripts/verify-public-ecosystem-index-echo-closure.mjs",
    "audit:rootless-reconstruction": "bash scripts/public-rootless-reconstruction-audit.sh",
    "verify:rootless-reconstruction": "node scripts/verify-public-rootless-reconstruction-index.mjs"
  },
  "bin": {
    "antimatterium-control-replay": "scripts/cold-replay.sh"
  },
  "license": "MIT"
}
