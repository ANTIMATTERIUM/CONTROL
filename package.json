{
  "name": "@antimatterium/control",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "description": "ANTIMATTERIUM public cold-replay control plane",
  "scripts": {
    "verify": "node scripts/verify-control.mjs && node scripts/scan-public-safety.mjs && node scripts/verify-ci-gate.mjs && node scripts/verify-ci-evidence-seal.mjs && node scripts/verify-bidirectional-public-closure.mjs",
    "replay": "bash scripts/cold-replay.sh",
    "scan": "node scripts/scan-public-safety.mjs",
    "verify:ci": "node scripts/verify-ci-gate.mjs",
    "verify:ci-evidence": "node scripts/verify-ci-evidence-seal.mjs",
    "verify:bidirectional-closure": "node scripts/verify-bidirectional-public-closure.mjs"
  },
  "bin": {
    "antimatterium-control-replay": "scripts/cold-replay.sh"
  },
